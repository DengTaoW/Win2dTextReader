import "ChaptersCollection.idl"; 


namespace Xuanwen.Novel
{
	[default_interface]
	runtimeclass NovelBook
	{
		NovelBook(String filePath);
		
		Windows.Foundation.IAsyncAction InitializeAsync(); 

		String Name{ get; };
		String FilePath{ get; }; 
		UInt32 TotalChars{ get; };
		ChaptersCollection Chapters{ get; };
	}
}