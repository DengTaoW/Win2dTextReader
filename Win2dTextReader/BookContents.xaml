<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Win2dTextReader.BookContents"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Win2dTextReader"
    xmlns:xw="using:Xuanwen.Novel"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="UserControl_Loaded"
    mc:Ignorable="d">

    <Border Padding="20" 
            BorderThickness="1"
            CornerRadius="{StaticResource OverlayCornerRadius}" 
            BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}">

        <Grid RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" /> 
            </Grid.RowDefinitions>

            <TextBlock FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Text="目录" />

            <ListView x:Name="ContentsListView" 
                      Grid.Row="1"
                      SelectionMode="Single" 
                      ItemsSource="{x:Bind ViewModel.CurrentBook.Chapters, Mode=OneWay}"
                      SelectedIndex="{x:Bind ViewModel.ChapterIndex, Mode=TwoWay}" >
                
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="xw:Chapter">
                        <TextBlock Text="{x:Bind Title}" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Border>
</UserControl>
