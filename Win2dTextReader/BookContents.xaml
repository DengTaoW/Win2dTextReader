<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Win2dTextReader.BookContents"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Win2dTextReader"
    xmlns:xw="using:Xuanwen.Novel"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Padding="20" 
            CornerRadius="{StaticResource OverlayCornerRadius}" 
            BorderThickness="1"
            BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}">
        <ListView x:Name="ContentsListView" SelectionMode="Single" SelectionChanged="ContentsListView_SelectionChanged" >
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="xw:Chapter">
                    <TextBlock Text="{x:Bind Title}" />
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Border>
</UserControl>
