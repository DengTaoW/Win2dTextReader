<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Win2dTextReader.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Win2dTextReader"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Border Padding="20" 
            CornerRadius="{StaticResource OverlayCornerRadius}" 
            BorderThickness="1"
            BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}">

        <Grid RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" >
                设置
            </TextBlock>

            <ScrollView HorizontalScrollMode="Disabled" VerticalScrollMode="Auto" Grid.Row="1">
                <StackPanel Orientation="Vertical" Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <TextBlock VerticalAlignment="Center"
                                   Text="字体大小：" />
                        
                        <ComboBox x:Name="FontSizeComboBox" 
                                  VerticalAlignment="Center"
                                  SelectionChanged="FontSizeComboBox_SelectionChanged"/>

                        <TextBlock VerticalAlignment="Center"
                                   Text="行高倍率：" />

                        <ComboBox x:Name="LineHeightComboBox" 
                                  VerticalAlignment="Center"
                                  SelectionChanged="LineHeightComboBox_SelectionChanged"/>

                    </StackPanel>
                    
                    
                </StackPanel>
            </ScrollView>

        </Grid>
    </Border>
</UserControl>
