<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Win2dTextReader.Settings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Win2dTextReader"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="DoubleItemDataTemplate" x:DataType="local:DoubleItem">
            <TextBlock Text="{x:Bind DisplayText}" /> 
        </DataTemplate>

        <DataTemplate x:Key="AppFontDataTemplate" x:DataType="local:AppFont" >
            <TextBlock Text="{x:Bind Name}" FontFamily="{x:Bind FontFamily}" /> 
        </DataTemplate>

        <DataTemplate x:Key="AppThemeDataTemplate" x:DataType="local:AppTheme">
            <Grid Background="{x:Bind Background}" Padding="5" CornerRadius="5">
                <TextBlock Text="{x:Bind Name}" Foreground="{x:Bind Foreground}" VerticalAlignment="Center" />
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="FontWeightItemDataTemplate" x:DataType="local:FontWeightItem">
            <TextBlock Text="{x:Bind Name}" FontWeight="{x:Bind FontWeight}" /> 
        </DataTemplate>
    </UserControl.Resources>

    <Border Padding="20" 
            BorderThickness="1"
            CornerRadius="{StaticResource OverlayCornerRadius}" 
            BorderBrush="{ThemeResource SurfaceStrokeColorDefaultBrush}"
            Background="{ThemeResource AcrylicBackgroundFillColorDefaultBrush}">

        <Grid RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Text="设置" />

            <Grid RowSpacing="10" ColumnSpacing="10" Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Row="0" Grid.Column="0"
                          Header="字体大小"
                          ItemsSource="{x:Bind ViewModel.FontSizeItems}"
                          ItemTemplate="{StaticResource DoubleItemDataTemplate}"
                          HorizontalAlignment="Stretch"
                          SelectedIndex="{x:Bind ViewModel.FontSizeIndex, Mode=TwoWay}" />

                <ComboBox Grid.Row="0" Grid.Column="1"
                          Header="字体名称"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{x:Bind ViewModel.FontItems}"
                          ItemTemplate="{StaticResource AppFontDataTemplate}"
                          SelectedIndex="{x:Bind ViewModel.FontFamilyIndex, Mode=TwoWay}" />

                <ComboBox Grid.Row="1" Grid.Column="0"
                          Header="行高"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{x:Bind ViewModel.LineHeightItems}"
                          ItemTemplate="{StaticResource DoubleItemDataTemplate}"
                          SelectedIndex="{x:Bind ViewModel.LineHeightIndex, Mode=TwoWay}" />

                <ComboBox Grid.Row="1" Grid.Column="1"
                          Header="阅读主题"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{x:Bind ViewModel.ThemeItems}"
                          ItemTemplate="{StaticResource AppThemeDataTemplate}"
                          SelectedIndex="{x:Bind ViewModel.ThemeIndex, Mode=TwoWay}" />

                <ComboBox Grid.Row="2" Grid.Column="0" 
                          Header="字体粗细"
                          HorizontalAlignment="Stretch"
                          ItemsSource="{x:Bind ViewModel.FontWeightItems}"
                          ItemTemplate="{StaticResource FontWeightItemDataTemplate}"
                          SelectedIndex="{x:Bind ViewModel.FontWeightIndex, Mode=TwoWay}" /> 
            </Grid>
        </Grid>
    </Border>
</UserControl>
