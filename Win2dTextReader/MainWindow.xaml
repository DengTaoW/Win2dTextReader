<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Win2dTextReader.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Win2dTextReader"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Closed="Window_Closed"
    Title="Win2dTextReader">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="{x:Bind ViewModel.AppTheme.Background, Mode=OneWay}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" /> 
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="10">
            <TextBlock Grid.Row="1" FontWeight="Bold" 
                       Foreground="{x:Bind ViewModel.AppTheme.Foreground, Mode=OneWay}">
                <Run Text="{x:Bind ViewModel.CurrentBook.Name, Mode=OneWay}" /> -
                <Run Text="{x:Bind ViewModel.CurrentChapter.Title, Mode=OneWay}" />
            </TextBlock>
        </Grid>

        <Grid Grid.Row="1" x:Name="ReaderRegion">
            <!-- 阅读区域 -->
            <ScrollView x:Name="ContentScrollView" 
                        ZoomMode="Disabled"
                        Padding="20 0"
                        HorizontalScrollMode="Disabled" 
                        ViewChanged="ContentScrollView_ViewChanged"
                        VerticalScrollMode="Auto">
                <TextBlock x:Name="ChapterContentTextBlock"
                           FontFamily="{x:Bind ViewModel.FontFamily, Mode=OneWay}"
                           LineHeight="{x:Bind ViewModel.LineHeight, Mode=OneWay}"
                           FontSize="{x:Bind ViewModel.FontSize, Mode=OneWay}"
                           Text="{x:Bind ViewModel.CurrentChapter.Text, Mode=OneWay}"
                           Foreground="{x:Bind ViewModel.AppTheme.Foreground, Mode=OneWay}"
                           LineStackingStrategy="BlockLineHeight"
                           TextWrapping="Wrap" />

                <ScrollView.ContextFlyout>
                    <MenuFlyout>
                        <MenuFlyoutItem Text="打开" Click="OnOpenButtonClicked">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="Control" Key="O" />
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>

                        <MenuFlyoutSeparator />

                        <MenuFlyoutItem Text="目录" Click="ShowContents">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="None" Key="F1" />
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>

                        <MenuFlyoutItem Text="设置" Click="ShowSettings">
                            <MenuFlyoutItem.KeyboardAccelerators>
                                <KeyboardAccelerator Modifiers="None" Key="F2" />
                            </MenuFlyoutItem.KeyboardAccelerators>
                        </MenuFlyoutItem>

                        <MenuFlyoutSeparator />

                        <MenuFlyoutSubItem Text="阅读" >
                            <MenuFlyoutItem Text="向上翻页" Click="OnReaderRegionScrollUp">
                                <MenuFlyoutItem.KeyboardAccelerators>
                                    <KeyboardAccelerator Modifiers="None" Key="Up" />
                                </MenuFlyoutItem.KeyboardAccelerators>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="向下翻页" Click="OnReaderRegionScrollDown">
                                <MenuFlyoutItem.KeyboardAccelerators>
                                    <KeyboardAccelerator Modifiers="None" Key="Down" />
                                </MenuFlyoutItem.KeyboardAccelerators>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="上一章" Click="OnPreviousChapterButtonClicked">
                                <MenuFlyoutItem.KeyboardAccelerators>
                                    <KeyboardAccelerator Modifiers="None" Key="Left" />
                                </MenuFlyoutItem.KeyboardAccelerators>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="下一章" Click="OnNextChapterButtonClicked" >
                                <MenuFlyoutItem.KeyboardAccelerators>
                                    <KeyboardAccelerator Modifiers="None" Key="Right" />
                                </MenuFlyoutItem.KeyboardAccelerators>
                            </MenuFlyoutItem>
                        </MenuFlyoutSubItem>
                    </MenuFlyout>
                </ScrollView.ContextFlyout>
            </ScrollView>
            
            <!-- 目录 -->
            <Popup x:Name="ContentsPopup" IsLightDismissEnabled="True"/>

            <!-- 设置 -->
            <Popup x:Name="SettingsPopup" IsLightDismissEnabled="True" /> 
        </Grid>
    </Grid>
</Window>
