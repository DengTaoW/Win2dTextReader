<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Win2dTextReader">

    <local:AppTheme x:Key="Theme_0" Name="Dark" Foreground="#EAEAEA">
        <local:AppTheme.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0.0" Color="#FF1A1A2E" />
                <GradientStop Offset="1.0" Color="#FF16213E" />
            </LinearGradientBrush>
        </local:AppTheme.Background>
    </local:AppTheme>

    <local:AppTheme x:Key="Theme_1" Name="Foreset" Foreground="#1B5E20">
        <local:AppTheme.Background>
            <LinearGradientBrush StartPoint="0.5, 0" EndPoint="0.5, 1">
                <GradientStop Offset="0.0" Color="#FFE8F5E9" />
                <GradientStop Offset="1.0" Color="#FFC8E6C9" />
            </LinearGradientBrush>
        </local:AppTheme.Background>
    </local:AppTheme>

    <local:AppTheme x:Key="Theme_2" Name="Ocean" Foreground="#006064">
        <local:AppTheme.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0" >
                <GradientStop Color="#FFE0F7FA" Offset="0.0" />
                <GradientStop Color="#FFB2EBF2" Offset="1.0" />
            </LinearGradientBrush>
        </local:AppTheme.Background>
    </local:AppTheme>

    <local:AppTheme x:Key="Theme_3" Name="Sister's Soft" Foreground="#4B0082">
        <local:AppTheme.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFF8F4FF" Offset="0.0" />
                <GradientStop Color="#FFFFF0F5" Offset="0.5" />
                <GradientStop Color="#FFF0F8FF" Offset="1.0" />
            </LinearGradientBrush>
        </local:AppTheme.Background>
    </local:AppTheme>

    <local:AppTheme x:Key="Theme_4" Name="Sakura" Foreground="#8b4367">
        <local:AppTheme.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0, 1" >
                <GradientStop Offset="0.0" Color="#FFFFF0F5" />
                <GradientStop Offset="1.0" Color="#FFFFE4E1" />
            </LinearGradientBrush>
        </local:AppTheme.Background>
    </local:AppTheme>

    <local:AppTheme x:Key="Theme_5" Name="Morning Snow" Foreground="#3E2723">
        <local:AppTheme.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FFEDBC" Offset="0.0" />
                <GradientStop Color="#ED4264" Offset="1.0" />
            </LinearGradientBrush>
        </local:AppTheme.Background>
    </local:AppTheme>

    <local:AppTheme x:Key="Theme_6" Name="Aurora" Foreground="#01579B">
        <local:AppTheme.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#00C9FF" Offset="0.0" />
