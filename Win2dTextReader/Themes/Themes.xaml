            </LinearGradientBrush>
        </local:AppTheme.Background>
    </local:AppTheme>

    <local:AppTheme x:Key="Theme_7" Name="Twilight Valley" Foreground="#F5F5F5">
        <local:AppTheme.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#134E5E" Offset="0.0" />
                <GradientStop Color="#71B280" Offset="1.0" />
            </LinearGradientBrush>
        </local:AppTheme.Background>
    </local:AppTheme>

    <local:AppTheme x:Key="Theme_8" Name="Dream Star" Foreground="#FFFFFF">
        <local:AppTheme.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#8E2DE2" Offset="0.0" />
                <GradientStop Color="#4A00E0" Offset="1.0" />
            </LinearGradientBrush>
        </local:AppTheme.Background>
