<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FFF8F4FF" Offset="0.0" />
        <GradientStop Color="#FFFFF0F5" Offset="0.5" />
        <GradientStop Color="#FFF0F8FF" Offset="1.0" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="AppFontColor" Color="#4B0082" /> 
</ResourceDictionary>
